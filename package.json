{
  "name": "epos-pharma",
  "version": "1.0.0",
  "description": "EPOS Pharma - Desktop Pharmacy POS System",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev:vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:vite": "vite",
    "build": "vite build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.0",
    "express": "^4.21.0",
    "jsbarcode": "^3.11.6",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.575.0",
    "node-thermal-printer": "^4.6.0",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "7zip-bin": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^5.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.14.1",
    "tailwindcss": "^3.4.19",
    "vite": "^6.0.0",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.epospharma.app",
    "productName": "EPOS Pharma",
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "backend/**/*",
      "utils/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EPOS Pharma"
    },
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "epos-pharma"
    }
  }
}
